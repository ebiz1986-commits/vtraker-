{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application, representing admins, drivers, or standard users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "driver", "user"] },
        "phone": { "type": "string" },
        "department": { "type": "string" },
        "hasSmartphone": { "type": "boolean" },
        "createdAt": { "type": "integer" }
      },
      "required": ["userId", "email", "role", "createdAt"]
    },
    "UserSecret": {
      "title": "UserSecret",
      "description": "Private PII data for a user.",
      "type": "object",
      "properties": {
        "phone": {"type": "string"}
      }
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "A vehicle available for booking.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["wagon r", "cab", "van", "bus", "car"] },
        "registrationNumber": { "type": "string" },
        "driverId": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "on_trip", "maintenance"] },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "lastUpdated": { "type": "integer" }
      },
      "required": ["type", "registrationNumber", "status"]
    },
    "Trip": {
      "title": "Trip",
      "description": "A booking request and active trip.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "driverId": { "type": "string" },
        "driverName": { "type": "string" },
        "driverPhone": { "type": "string" },
        "driverHasSmartphone": { "type": "boolean" },
        "vehicleId": { "type": "string" },
        "vehicleName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "allocated", "in_progress", "completed", "cancelled"] },
        "tripType": { "type": "string", "enum": ["dropoff", "return"] },
        "pickupAddress": { "type": "string" },
        "dropoffAddress": { "type": "string" },
        "returnLocations": { "type": "string" },
        "remarks": { "type": "string" },
        "pickupLat": { "type": "number" },
        "pickupLng": { "type": "number" },
        "dropoffLat": { "type": "number" },
        "dropoffLng": { "type": "number" },
        "pickupTime": { "type": "integer" },
        "dropoffTime": { "type": "integer" },
        "nominatedUserId": { "type": "string" },
        "nominatedName": { "type": "string" },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["userId", "status", "pickupAddress", "pickupLat", "pickupLng", "dropoffLat", "dropoffLng", "pickupTime", "createdAt", "updatedAt"]
    },
    "Timesheet": {
      "title": "Timesheet",
      "description": "Daily timesheet for drivers.",
      "type": "object",
      "properties": {
        "driverId": { "type": "string" },
        "date": { "type": "string" },
        "totalHours": { "type": "number" },
        "tripsCompleted": { "type": "integer" }
      },
      "required": ["driverId", "date", "totalHours", "tripsCompleted"]
    },
    "SystemSettings": {
      "title": "SystemSettings",
      "description": "System flow configuration (normal vs simulation).",
      "type": "object",
      "properties": {
        "normal": { "type": "boolean" }
      }
    },
    "FuelRecord": {
      "title": "FuelRecord",
      "description": "Fuel logging entry recorded by admins for tracking and vehicle consumption analysis.",
      "type": "object",
      "properties": {
        "vehicleId": { "type": "string" },
        "vehicleRegistration": { "type": "string" },
        "liters": { "type": "number" },
        "odometer": { "type": "number" },
        "timestamp": { "type": "integer" },
        "recordedBy": { "type": "string" },
        "recordedByName": { "type": "string" },
        "createdAt": { "type": "integer" },
        "cost": { "type": "number" }
      },
      "required": ["vehicleId", "vehicleRegistration", "liters", "odometer", "timestamp", "createdAt"]
    },
    "ComplianceRecord": {
      "title": "ComplianceRecord",
      "description": "Vehicle compliance details including revenue license, insurance policy, and latest annual valuation.",
      "type": "object",
      "properties": {
        "vehicleId": { "type": "string" },
        "vehicleRegistration": { "type": "string" },
        "revenueLicenseNo": { "type": "string" },
        "revenueLicenseExpiry": { "type": "integer" },
        "revenueLicenseFee": { "type": "number" },
        "insuranceProvider": { "type": "string" },
        "insurancePolicyNo": { "type": "string" },
        "insuranceExpiry": { "type": "integer" },
        "insurancePremium": { "type": "number" },
        "valuationAmount": { "type": "number" },
        "valuationDate": { "type": "integer" },
        "valuationCompany": { "type": "string" },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["vehicleId", "vehicleRegistration", "revenueLicenseExpiry", "insuranceExpiry", "valuationAmount", "createdAt", "updatedAt"]
    },
    "AccidentRecord": {
      "title": "AccidentRecord",
      "description": "Logs of accidents and related insurance claims.",
      "type": "object",
      "properties": {
        "vehicleId": { "type": "string" },
        "vehicleRegistration": { "type": "string" },
        "driverId": { "type": "string" },
        "driverName": { "type": "string" },
        "accidentDate": { "type": "integer" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "severity": { "type": "string", "enum": ["minor", "moderate", "major"] },
        "hasClaim": { "type": "boolean" },
        "claimStatus": { "type": "string", "enum": ["none", "pending", "approved", "rejected"] },
        "claimAmountRequested": { "type": "number" },
        "claimAmountApproved": { "type": "number" },
        "insuranceRefNo": { "type": "string" },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["vehicleId", "vehicleRegistration", "accidentDate", "severity", "hasClaim", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Public profiles and roles for all users."
    },
    "/vehicles/{vehicleId}": {
      "schema": { "$ref": "#/entities/Vehicle" },
      "description": "Vehicles available in the system."
    },
    "/trips/{tripId}": {
      "schema": { "$ref": "#/entities/Trip" },
      "description": "Bookings and active trips."
    },
    "/timesheets/{timesheetId}": {
      "schema": { "$ref": "#/entities/Timesheet" },
      "description": "Driver timesheets."
    },
    "/settings/{settingsId}": {
      "schema": { "$ref": "#/entities/SystemSettings" },
      "description": "Global system configurations."
    },
    "/fuel_records/{recordId}": {
      "schema": { "$ref": "#/entities/FuelRecord" },
      "description": "Fuel recording logs for consumption analysis."
    },
    "/compliance_records/{complianceId}": {
      "schema": { "$ref": "#/entities/ComplianceRecord" },
      "description": "Compliance records including revenue license, insurance, and valuations."
    },
    "/accident_records/{accidentId}": {
      "schema": { "$ref": "#/entities/AccidentRecord" },
      "description": "Accident history logs and insurance claim details."
    }
  }
}
