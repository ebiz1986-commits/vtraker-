rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // We check admin from users col with safe token-based verification fallbacks
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email in ['ebiz1986@gmail.com', '445566@sanken.app'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    // We check driver with safe token-based verification fallbacks
    function isDriver() {
      return isSignedIn() && (
        request.auth.token.email in ['222222@sanken.app', 'ebiz1986@gmail.com', '445566@sanken.app'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'driver' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        ))
      );
    }

    match /users/{userId} {
      function isValidUser(data) {
        return data.userId is string && data.userId.size() <= 128
          && data.email is string && data.email.size() <= 200
          && (!('name' in data) || (data.name is string && data.name.size() <= 100))
          && data.role in ['admin', 'driver', 'user']
          && (!('phone' in data) || (data.phone is string && data.phone.size() <= 20))
          && (!('department' in data) || (data.department is string && data.department.size() <= 100))
          && (!('hasSmartphone' in data) || (data.hasSmartphone is bool))
          && data.createdAt is timestamp;
      }

      allow get: if isSignedIn() && (isAdmin() || userId == request.auth.uid);
      allow list: if isSignedIn() && (request.auth.token.email in ['ebiz1986@gmail.com', '445566@sanken.app'] || resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() && isValidId(userId) && isValidUser(incoming())
        && incoming().keys().hasAll(['userId', 'email', 'role', 'createdAt']) && incoming().keys().size() <= 8
        && incoming().createdAt == request.time
        && (
          (request.auth.uid == userId && (
            (incoming().role == 'user') || 
            (incoming().role == 'admin' && (request.auth.token.email == 'ebiz1986@gmail.com' || request.auth.token.email == '445566@sanken.app')) ||
            (incoming().role == 'driver' && request.auth.token.email == '222222@sanken.app')
          )) ||
          isAdmin()
        );
        
      allow update: if isSignedIn() && isValidId(userId) && isValidUser(incoming()) && (
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'department', 'hasSmartphone']) && incoming().role == existing().role) ||
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['role']) && (
            (incoming().role == 'admin' && (request.auth.token.email == 'ebiz1986@gmail.com' || request.auth.token.email == '445566@sanken.app')) ||
            (incoming().role == 'driver' && request.auth.token.email == '222222@sanken.app')
        )) ||
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'role', 'department', 'hasSmartphone']))
      );
      
      allow delete: if isAdmin();
    }
    
    match /vehicles/{vehicleId} {
      function isValidVehicle(data) {
        return data.type in ['wagon r', 'cab', 'van', 'bus', 'car']
          && data.registrationNumber is string && data.registrationNumber.size() <= 30
          && data.status in ['available', 'on_trip', 'maintenance']
          && (!('driverId' in data) || (data.driverId is string && data.driverId.size() <= 128))
          && (!('lat' in data) || (data.lat is number))
          && (!('lng' in data) || (data.lng is number))
          && (!('lastUpdated' in data) || (data.lastUpdated is timestamp));
      }

      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidId(vehicleId) && isValidVehicle(incoming())
        && incoming().keys().hasAll(['type', 'registrationNumber', 'status']) && incoming().keys().size() <= 7;
        
      allow update: if isSignedIn() && isValidId(vehicleId) && isValidVehicle(incoming()) && (
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['type', 'registrationNumber', 'status', 'driverId', 'lat', 'lng', 'lastUpdated'])) ||
        (isDriver() && existing().driverId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'lat', 'lng', 'lastUpdated']) && incoming().lastUpdated == request.time)
      );
      
      allow delete: if isAdmin();
    }
    
    match /trips/{tripId} {
      function isValidTrip(data) {
        return data.userId is string && data.userId.size() <= 128
          && data.status in ['pending', 'allocated', 'driver_started', 'in_progress', 'driver_ended', 'completed', 'cancelled']
          && (!('tripType' in data) || data.tripType in ['dropoff', 'return'])
          && data.pickupAddress is string && data.pickupAddress.size() <= 500
          && (!('dropoffAddress' in data) || data.dropoffAddress == null || (data.dropoffAddress is string && data.dropoffAddress.size() <= 500))
          && (!('returnLocations' in data) || data.returnLocations == null || (data.returnLocations is string && data.returnLocations.size() <= 1500))
          && (!('remarks' in data) || data.remarks == null || (data.remarks is string && data.remarks.size() <= 1000))
          && (!('pickupLat' in data) || data.pickupLat is number)
          && (!('pickupLng' in data) || data.pickupLng is number)
          && (!('dropoffLat' in data) || data.dropoffLat is number)
          && (!('dropoffLng' in data) || data.dropoffLng is number)
          && (!('pickupTime' in data) || data.pickupTime is number)
          && (!('requestedStartTime' in data) || (data.requestedStartTime is string && data.requestedStartTime.size() <= 50))
          && (!('passengerCount' in data) || (data.passengerCount is number))
          && (!('passengerName' in data) || (data.passengerName is string && data.passengerName.size() <= 100))
          && (!('passengerDepartment' in data) || (data.passengerDepartment is string && data.passengerDepartment.size() <= 100))
          && (!('jointPassengers' in data) || (data.jointPassengers is list && data.jointPassengers.size() <= 20))
          && (!('vehicleId' in data) || (data.vehicleId is string && data.vehicleId.size() <= 128))
          && (!('driverId' in data) || (data.driverId is string && data.driverId.size() <= 128))
          && (!('driverName' in data) || (data.driverName is string && data.driverName.size() <= 100))
          && (!('driverPhone' in data) || (data.driverPhone is string && data.driverPhone.size() <= 50))
          && (!('driverHasSmartphone' in data) || (data.driverHasSmartphone is bool))
          && (!('vehicleName' in data) || (data.vehicleName is string && data.vehicleName.size() <= 150))
          && (!('allocatedAt' in data) || (data.allocatedAt is timestamp))
          && (!('dropoffTime' in data) || (data.dropoffTime is number))
          && (!('driverStartedTime' in data) || (data.driverStartedTime is number))
          && (!('driverEndedTime' in data) || (data.driverEndedTime is number))
          && (!('startOdometer' in data) || (data.startOdometer is number))
          && (!('endOdometer' in data) || (data.endOdometer is number))
          && (!('currentOdometer' in data) || (data.currentOdometer is number))
          && (!('expectedEndOdometer' in data) || (data.expectedEndOdometer is number))
          && (!('currentLocation' in data) || (data.currentLocation is map))
          && (!('pickupCoords' in data) || (data.pickupCoords is map))
          && (!('dropoffCoords' in data) || (data.dropoffCoords is map))
          && (!('forceCompleted' in data) || (data.forceCompleted is bool))
          && (!('isJointTrip' in data) || (data.isJointTrip is bool))
          && (!('expectedDistance' in data) || (data.expectedDistance is number))
          && (!('requestedDate' in data) || (data.requestedDate is string && data.requestedDate.size() <= 50))
          && (!('estimatedDestinationTime' in data) || data.estimatedDestinationTime == null || (data.estimatedDestinationTime is string && data.estimatedDestinationTime.size() <= 50))
          && (!('nominatedUserId' in data) || data.nominatedUserId == null || (data.nominatedUserId is string && data.nominatedUserId.size() <= 128))
          && (!('nominatedName' in data) || data.nominatedName == null || (data.nominatedName is string && data.nominatedName.size() <= 100))
          && data.createdAt is timestamp
          && data.updatedAt is timestamp;
      }

      function isParticipant(trip) {
        return trip.userId == request.auth.uid || ('nominatedName' in trip && 'name' in request.auth.token && trip.nominatedName == request.auth.token.name);
      }

      allow get: if isSignedIn() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid ||
        ('driverId' in resource.data && resource.data.driverId == request.auth.uid) ||
        ('nominatedName' in resource.data && 'name' in request.auth.token && resource.data.nominatedName == request.auth.token.name)
      );
      
      allow list: if isSignedIn() && (
        request.auth.token.email in ['ebiz1986@gmail.com', '445566@sanken.app'] ||
        resource.data.userId == request.auth.uid ||
        ('driverId' in resource.data && resource.data.driverId == request.auth.uid) ||
        ('nominatedName' in resource.data && 'name' in request.auth.token && resource.data.nominatedName == request.auth.token.name)
      );

      allow create: if isSignedIn() && isValidId(tripId) && isValidTrip(incoming())
        && incoming().keys().hasAll(['userId', 'status', 'pickupAddress', 'pickupLat', 'pickupLng', 'dropoffLat', 'dropoffLng', 'pickupTime', 'createdAt', 'updatedAt']) 
        && incoming().keys().size() <= 35
        && incoming().userId == request.auth.uid
        && incoming().status == 'pending'
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
       allow update: if isSignedIn() && isValidId(tripId) && isValidTrip(incoming()) && incoming().updatedAt == request.time && (
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'driverId', 'driverName', 'driverPhone', 'driverHasSmartphone', 'vehicleId', 'vehicleName', 'allocatedAt', 'updatedAt', 'requestedStartTime', 'pickupTime', 'remarks', 'dropoffTime', 'forceCompleted', 'isJointTrip', 'jointPassengers', 'startOdometer', 'endOdometer', 'currentOdometer', 'expectedEndOdometer', 'driverStartedTime', 'driverEndedTime', 'nominatedUserId', 'nominatedName', 'currentLocation', 'pickupCoords', 'dropoffCoords'])) ||
        (isDriver() && existing().driverId == request.auth.uid && !(existing().status in ['completed', 'cancelled']) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'driverStartedTime', 'driverEndedTime', 'startOdometer', 'endOdometer', 'currentOdometer', 'currentLocation', 'pickupCoords', 'dropoffCoords', 'expectedEndOdometer', 'pickupTime', 'dropoffTime'])) ||
        (isParticipant(existing()) && existing().status == 'pending' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && incoming().status == 'cancelled') ||
        (isParticipant(existing()) && existing().status == 'allocated' && existing().driverHasSmartphone == false && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'driverStartedTime']) && incoming().status == 'driver_started') ||
        (isParticipant(existing()) && existing().status == 'driver_started' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'startOdometer', 'currentOdometer', 'expectedEndOdometer']) && incoming().status == 'in_progress') ||
        (isParticipant(existing()) && existing().status == 'in_progress' && existing().driverHasSmartphone == false && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'driverEndedTime']) && incoming().status == 'driver_ended') ||
        (isParticipant(existing()) && existing().status == 'driver_ended' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'dropoffTime', 'endOdometer']) && incoming().status == 'completed')
      );
      
      allow delete: if isAdmin();
    }
    
    match /timesheets/{timesheetId} {
      function isValidTimesheet(data) {
        return data.driverId is string && data.driverId.size() <= 128
          && data.date is string && data.date.size() <= 15
          && data.totalHours is number
          && data.tripsCompleted is number
          && data.createdAt is timestamp;
      }
      
      allow get: if isSignedIn() && (isAdmin() || resource.data.driverId == request.auth.uid);
      allow list: if isSignedIn() && (request.auth.token.email in ['ebiz1986@gmail.com', '445566@sanken.app'] || resource.data.driverId == request.auth.uid);
      
      allow create: if isSignedIn() && isValidId(timesheetId) && isValidTimesheet(incoming())
        && incoming().keys().hasAll(['driverId', 'date', 'totalHours', 'tripsCompleted', 'createdAt'])
        && incoming().keys().size() <= 5
        && incoming().driverId == request.auth.uid
        && incoming().createdAt == request.time;
        
      allow update: if isSignedIn() && isValidId(timesheetId) && isValidTimesheet(incoming()) && (
        (isDriver() && existing().driverId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['totalHours', 'tripsCompleted'])) ||
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['totalHours', 'tripsCompleted']))
      );
      
      allow delete: if isAdmin();
    }
    
    match /settings/{settingsId} {
      function isValidSettings(data) {
        return (!('normal' in data) || (data.normal is bool));
      }

      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidSettings(incoming());
    }
  }
}
